# テスト用環境変数テンプレート
# このファイルをコピーして値を設定してください:
#   cp .env.test .env.test.local
#
# 実API統合テスト実行:
#   source .env.test.local && cargo test -- --ignored

# GitHub Personal Access Token (repo スコープ必要)
GITHUB_TOKEN=ghp_your_token_here

# テスト対象リポジトリ (デフォルト: octocat/Hello-World)
GITHUB_TEST_OWNER=octocat
GITHUB_TEST_REPO=Hello-World

# テストモード有効化 (固定レスポンスを返す)
# DEVNEST_TEST_MODE=1
